# Drifter secrets and env-only configuration
# Copy to .env and fill in values as needed.
#
# The CLI auto-loads .env from the project root — no need to export variables.
# Non-secret settings should go in config.yaml instead.
# By default, all services use in-memory adapters (no external services).
# Set the trigger variable for each service to activate its real adapter.
#
# NOTE: When using config.yaml, most settings move there. This file is only
# needed for secrets (API keys, passwords) and env-var fallback mode.

# --------------------------------------------------------------------------
# Qdrant (dense vector retrieval)
# Trigger: DRIFTER_QDRANT_HOST
# --------------------------------------------------------------------------
# DRIFTER_QDRANT_HOST=localhost
# DRIFTER_QDRANT_PORT=6333
# DRIFTER_QDRANT_GRPC_PORT=6334
# DRIFTER_QDRANT_API_KEY=
# DRIFTER_QDRANT_COLLECTION=drifter
# DRIFTER_QDRANT_TIMEOUT_S=10.0
# DRIFTER_QDRANT_USE_TLS=false

# --------------------------------------------------------------------------
# OpenSearch (lexical retrieval + optional vector)
# Trigger: DRIFTER_OPENSEARCH_HOSTS (comma-separated)
# --------------------------------------------------------------------------
# DRIFTER_OPENSEARCH_HOSTS=localhost:9200
# DRIFTER_OPENSEARCH_USERNAME=admin
# DRIFTER_OPENSEARCH_PASSWORD=admin
# DRIFTER_OPENSEARCH_INDEX_PREFIX=drifter
# DRIFTER_OPENSEARCH_USE_SSL=false
# DRIFTER_OPENSEARCH_TIMEOUT_S=10.0

# --------------------------------------------------------------------------
# TEI — Text Embeddings Inference (embeddings + reranking)
# Trigger: DRIFTER_TEI_URL
# --------------------------------------------------------------------------
# DRIFTER_TEI_URL=http://localhost:8090
# DRIFTER_TEI_RERANKER_URL=http://localhost:8091
# DRIFTER_TEI_MODEL_ID=nomic-ai/nomic-embed-text-v1.5
# DRIFTER_TEI_MODEL_VERSION=
# DRIFTER_TEI_RERANKER_MODEL_ID=Alibaba-NLP/gte-reranker-modernbert-base
# DRIFTER_TEI_TIMEOUT_S=30.0
# DRIFTER_TEI_MAX_BATCH_SIZE=32

# --------------------------------------------------------------------------
# HuggingFace Inference API (reranking)
# Trigger: DRIFTER_HF_TOKEN
# --------------------------------------------------------------------------
# DRIFTER_HF_TOKEN=your-hf-token-here
# DRIFTER_HF_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# DRIFTER_HF_PROVIDER=hf-inference
# DRIFTER_HF_TIMEOUT_S=30.0

# --------------------------------------------------------------------------
# OpenRouter (LLM gateway — hundreds of models via OpenAI-compatible API)
# Trigger: DRIFTER_OPENROUTER_API_KEY
# --------------------------------------------------------------------------
# DRIFTER_OPENROUTER_API_KEY=
# DRIFTER_OPENROUTER_MODEL=openai/gpt-4o
# DRIFTER_OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# DRIFTER_OPENROUTER_BASE_URL=https://openrouter.ai/api
# DRIFTER_OPENROUTER_APP_NAME=drifter
# DRIFTER_OPENROUTER_TIMEOUT_S=60.0
# DRIFTER_OPENROUTER_MAX_TOKENS=1024
# DRIFTER_OPENROUTER_MAX_BATCH_SIZE=32
# DRIFTER_OPENROUTER_TEMPERATURE=0.1

# --------------------------------------------------------------------------
# OpenAI (LLM generation)
# Trigger: DRIFTER_OPENAI_API_KEY
# --------------------------------------------------------------------------
# DRIFTER_OPENAI_API_KEY=
# DRIFTER_OPENAI_MODEL=gpt-4o
# DRIFTER_OPENAI_BASE_URL=https://api.openai.com
# DRIFTER_OPENAI_TIMEOUT_S=60.0
# DRIFTER_OPENAI_MAX_TOKENS=1024
# DRIFTER_OPENAI_TEMPERATURE=0.1

# --------------------------------------------------------------------------
# Ollama (local LLM generation)
# Trigger: DRIFTER_OLLAMA_URL
# --------------------------------------------------------------------------
# DRIFTER_OLLAMA_URL=http://localhost:11434
# DRIFTER_OLLAMA_MODEL=llama3.2
# DRIFTER_OLLAMA_TIMEOUT_S=120.0
# DRIFTER_OLLAMA_NUM_PREDICT=1024
# DRIFTER_OLLAMA_NUM_CTX=2048
# DRIFTER_OLLAMA_TEMPERATURE=0.1
# DRIFTER_OLLAMA_TOP_K=40
# DRIFTER_OLLAMA_TOP_P=0.9
# DRIFTER_OLLAMA_MIN_P=0.0
# DRIFTER_OLLAMA_SEED=
# DRIFTER_OLLAMA_REPEAT_PENALTY=1.1
# DRIFTER_OLLAMA_REPEAT_LAST_N=64
# DRIFTER_OLLAMA_STOP=
# DRIFTER_OLLAMA_KEEP_ALIVE=5m

# --------------------------------------------------------------------------
# Google Gemini (LLM generation)
# Trigger: DRIFTER_GEMINI_API_KEY
# --------------------------------------------------------------------------
# DRIFTER_GEMINI_API_KEY=
# DRIFTER_GEMINI_MODEL=gemini-2.5-flash
# DRIFTER_GEMINI_TIMEOUT_S=60.0
# DRIFTER_GEMINI_MAX_TOKENS=1024
# DRIFTER_GEMINI_TEMPERATURE=0.1

# --------------------------------------------------------------------------
# vLLM (local GPU generation + embeddings)
# Configure in config.yaml — no secrets needed for local vLLM.
# Generation: vllm serve Qwen/Qwen3-8B-AWQ --port 8000 ...
# Embeddings: vllm serve nomic-ai/nomic-embed-text-v1.5 --port 8001 ...
# --------------------------------------------------------------------------
# (No env vars — vLLM config is in config.yaml: vllm.base_url, vllm.model_id, etc.)

# --------------------------------------------------------------------------
# Local CPU Reranker (cross-encoder via transformers)
# Configure in config.yaml — no secrets needed.
# Requires: uv sync --extra reranker
# --------------------------------------------------------------------------
# (No env vars — config in config.yaml: local_reranker.model_id, local_reranker.timeout_s)

# --------------------------------------------------------------------------
# OpenTelemetry (tracing via Jaeger)
# Trigger: DRIFTER_OTEL_ENDPOINT
# --------------------------------------------------------------------------
# DRIFTER_OTEL_ENDPOINT=http://localhost:4318
# DRIFTER_OTEL_PROTOCOL=http/protobuf
# DRIFTER_OTEL_SERVICE_NAME=drifter
# DRIFTER_OTEL_EXPORT_INTERVAL_MS=5000
# DRIFTER_OTEL_INSECURE=true

# --------------------------------------------------------------------------
# Postgres (relational storage — planned, no adapter yet)
# --------------------------------------------------------------------------
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=drifter
# POSTGRES_PASSWORD=drifter
# POSTGRES_DB=drifter

# --------------------------------------------------------------------------
# MinIO (blob storage — planned, no adapter yet)
# --------------------------------------------------------------------------
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=drifter
# MINIO_SECRET_KEY=drifter123
# MINIO_BUCKET=drifter-raw

# --------------------------------------------------------------------------
# Unstructured (PDF parsing)
# Trigger: DRIFTER_UNSTRUCTURED_URL
# --------------------------------------------------------------------------
# DRIFTER_UNSTRUCTURED_URL=http://localhost:8000
# DRIFTER_UNSTRUCTURED_STRATEGY=auto
# DRIFTER_UNSTRUCTURED_TIMEOUT_S=60.0

# --------------------------------------------------------------------------
# Apache Tika (PDF parsing)
# Trigger: DRIFTER_TIKA_URL
# --------------------------------------------------------------------------
# DRIFTER_TIKA_URL=http://localhost:9998
# DRIFTER_TIKA_TIMEOUT_S=30.0

# --------------------------------------------------------------------------
# Langfuse (LLM observability)
# Trigger: DRIFTER_LANGFUSE_PUBLIC_KEY
# --------------------------------------------------------------------------
# DRIFTER_LANGFUSE_PUBLIC_KEY=pk-lf-drifter-dev
# DRIFTER_LANGFUSE_SECRET_KEY=sk-lf-drifter-dev
# DRIFTER_LANGFUSE_HOST=http://localhost:3000
# DRIFTER_LANGFUSE_REDIS_URL=redis://:drifter-redis@localhost:6379
# DRIFTER_LANGFUSE_BUFFER_TTL_S=300

# --------------------------------------------------------------------------
# Ragas (answer evaluation)
# Trigger: DRIFTER_RAGAS_MODEL
# --------------------------------------------------------------------------
# DRIFTER_RAGAS_MODEL=
# DRIFTER_RAGAS_METRICS=faithfulness,answer_relevancy
